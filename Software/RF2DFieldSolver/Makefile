	$(COPY_FILE) --parents CustomWidgets/informationbox.cpp CustomWidgets/pcbview.cpp CustomWidgets/siunitedit.cpp Scenarios/coplanardifferentialmicrostrip.cpp Scenarios/customcoplanardifferentialmicrostrip.cpp Scenarios/coplanardifferentialstripline.cpp Scenarios/coplanarmicrostrip.cpp Scenarios/customcoplanarmicrostrip.cpp Scenarios/coplanarstripline.cpp Scenarios/differentialmicrostrip.cpp Scenarios/customdifferentialmicrostrip.cpp Scenarios/differentialstripline.cpp Scenarios/custommicrostrip.cpp Scenarios/microstrip.cpp Scenarios/scenario.cpp Scenarios/stripline.cpp element.cpp elementlist.cpp gauss/gauss.cpp laplace/laplace.cpp laplace/lattice.c laplace/worker.c main.cpp mainwindow.cpp polygon.cpp savable.cpp unit.cpp util.cpp $(DISTDIR)/
